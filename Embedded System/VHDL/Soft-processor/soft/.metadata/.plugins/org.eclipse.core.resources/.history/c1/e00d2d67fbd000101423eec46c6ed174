#include <stdio.h>
#include <unistd.h> // for usleep
#include <stdint.h>
#include "system.h"
#include "altera_avalon_i2c.h"
#include "altera_avalon_pio_regs.h"

//CtrlB to compile quickly the file

// Adress I2C of ADXL345
#define ADXL345_ADDR 0x53

int main(void)
{
    ALT_AVALON_I2C_DEV_t *i2c_dev = alt_avalon_i2c_open("/dev/i2c_0");

    //configuration if the slave adress
    alt_avalon_i2c_master_target_set(i2c_dev, ADXL345_ADDR);

    // Configuration of ADXL345
    // writing 0x08 (Measure bit) in register 0x2D (POWER_CTL)
    uint8_t tx_cfg[2] = {0x2D, 0x08};
    alt_avalon_i2c_master_tx(i2c_dev, tx_cfg, 2, ALT_AVALON_I2C_NO_INTERRUPTS);

    // Buffer fo data
    uint8_t reg_addr = 0x32; // start (DATAX0)
    uint8_t data[6];         // to stock X0, X1, Y0, Y1, Z0, Z1
    int16_t x;

    while (1)
    {
        // reading data
        // we are sending the adress of register (0x32)
        ALT_AVALON_I2C_STATUS_CODE status = alt_avalon_i2c_master_tx_rx(
            i2c_dev,
            &reg_addr, 1,
            data, 6,
            ALT_AVALON_I2C_NO_INTERRUPTS
        );

		x = (int16_t)((data[1] << 8) | data[0]);

		// 4. Logic of "niveau à bulle"
		// L'accéléromètre renvoie environ +/- 256 pour 1g (selon config par défaut)
		// On veut afficher "la bulle" sur les 10 LEDs.

		// On divise X pour réduire la sensibilité.
		// Si la carte penche à gauche, X change, on déplace la LED.
		// +5 permet de centrer la "bulle" sur la LED 5 quand X=0.
		int led_pos = 5 + (x / 32);

		// Sécurité pour ne pas dépasser les bords (0 à 9)
		if (led_pos < 0) led_pos = 0;
		if (led_pos > 9) led_pos = 9;

		// Affichage
		IOWR_ALTERA_AVALON_PIO_DATA(PIO_0_BASE, (1 << led_pos));

        usleep(50000); // 50ms de pause
    }

    return 0;
}

