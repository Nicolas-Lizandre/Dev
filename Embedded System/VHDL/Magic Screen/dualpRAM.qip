set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "dualpRAM_inst.vhd"]
set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "dualpRAM.inc"]
set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "dualpRAM.cmp"]
