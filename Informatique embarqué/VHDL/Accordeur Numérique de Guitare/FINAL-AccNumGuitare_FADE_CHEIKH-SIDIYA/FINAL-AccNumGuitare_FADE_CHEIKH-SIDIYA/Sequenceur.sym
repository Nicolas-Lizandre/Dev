VERSION 5
BEGIN SYMBOL Sequenceur
SYMBOLTYPE BLOCK
TIMESTAMP 2025 12 16 14 8 2
SYMPIN 0 -224 Input Etat_0
SYMPIN 0 -128 Input Mesure
SYMPIN 384 -160 Output Init_Compt
SYMPIN 384 -224 Output Charg_Reg
SYMPIN 384 -96 Output Valid_Compt
SYMPIN 384 -32 Output SensCroiss
SYMPIN 0 96 Input Clk
BEGIN DISPLAY 192 -264 ATTR SymbolName
    ALIGNMENT BCENTER
    FONT 56 "Arial"
END DISPLAY
BEGIN DISPLAY 72 -224 PIN Etat_0 ATTR PinName
    FONT 24 "Arial"
END DISPLAY
BEGIN DISPLAY 72 -128 PIN Mesure ATTR PinName
